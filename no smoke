



(function() {
    // Check if smoke exists before deleting
    if (elements.smoke) {
        // Delete the base definition
        delete elements.smoke;
        
        // Overwrite the smoke key with an empty object 
        // to catch any dangling reaction references
        elements.smoke = {
            hidden: true,
            onStep: function(pixel) {
                deletePixel(pixel.x, pixel.y);
            }
        };

        console.log("SUCCESS: Smoke has been cleared from existence.");
    }
})();
