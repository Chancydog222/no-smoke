If the previous methods failed, it means the smoke is likely being generated by a hard-coded function or a high-priority class that runs after the mods load.

To stop this once and for all, we will use a Mutation Observer and a Function Proxy. This doesn't just change the element; it hijacks the game's internal "Create Pixel" logic. If the game tries to place a pixel with the ID smoke, the engine will now simply ignore the command.

The "Universal Silence" Mod
JavaScript
/*
 * +---------------------------------------+
 * |        THE SMOKE TERMINATOR           |
 * |      ---------------------------      |
 * |  [ TARGET ] : internal.createPixel    |
 * |  [ TYPE   ] : Logic Hijack            |
 * |  [ RANGE  ] : Global engine           |
 * +---------------------------------------+
 */

(function() {
    // 1. Hijack the global createPixel function
    // This catches smoke BEFORE it is even added to the grid.
    const originalCreatePixel = window.createPixel;
    window.createPixel = function(element, x, y, temp, color) {
        if (element === "smoke") {
            return false; // Denial of existence
        }
        return originalCreatePixel(element, x, y, temp, color);
    };

    // 2. The "Scorched Earth" loop
    // This turns the smoke element into a literal nothingness.
    function absolutePurge() {
        if (elements.smoke) {
            // Change its behavior to "nothing"
            elements.smoke.behavior = ["XX|XX|XX","XX|XX|XX","XX|XX|XX"];
            elements.smoke.color = "#00000000";
            elements.smoke.hidden = true;
            elements.smoke.state = "gas";
            // Ensure it has no temperature reactions
            elements.smoke.tempHigh = 999999;
            elements.smoke.tempLow = -999999;
        }

        // 3. Remove "smoke" as a product from every other element
        for (let key in elements) {
            let el = elements[key];
            if (el.burnInto === "smoke") { el.burnInto = null; }
            if (el.reactions) {
                for (let r in el.reactions) {
                    if (el.reactions[r].elem1 === "smoke") { el.reactions[r].elem1 = null; }
                    if (el.reactions[r].elem2 === "smoke") { el.reactions[r].elem2 = null; }
                }
            }
        }
    }

    // Execute at high frequency
    setInterval(absolutePurge, 10);
    absolutePurge();

    console.log("CRITICAL: Smoke creation logic has been intercepted.");
})();
