
setInterval(function() {
    // 1. Check if smoke exists in the element registry
    if (elements.smoke) {
        // 2. Erase its properties and hide it
        elements.smoke.color = "#00000000";
        elements.smoke.hidden = true;
        
        // 3. Force any existing smoke pixels to disappear
        elements.smoke.onStep = function(pixel) {
            deletePixel(pixel.x, pixel.y);
        };

        // 4. Remove the reference entirely
        delete elements.smoke;
    }
}, 100);
