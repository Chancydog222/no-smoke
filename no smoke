(function() {
    // 1. Hijack the element definition to be invisible and non-existent
    const purgeSmoke = () => {
        if (elements.smoke) {
            elements.smoke.color = "#00000000";
            elements.smoke.hidden = true;
            elements.smoke.state = "gas";
            // Any smoke that manages to spawn deletes itself instantly
            elements.smoke.onStep = function(pixel) {
                deletePixel(pixel.x, pixel.y);
            };
        }

        // 2. Scan EVERY element for reactions that produce smoke
        for (let name in elements) {
            let el = elements[name];
            if (el.reactions) {
                for (let r in el.reactions) {
                    if (el.reactions[r].elem1 === "smoke") { el.reactions[r].elem1 = null; }
                    if (el.reactions[r].elem2 === "smoke") { el.reactions[r].elem2 = null; }
                }
            }
            // 3. Stop elements from "burning" into smoke
            if (el.burnInto === "smoke") {
                el.burnInto = null;
            }
        }
    };

    // Run the purge every 50ms to catch any late-loading mods
    setInterval(purgeSmoke, 50);
    purgeSmoke();

    console.log("Smoke logic has been purged from the engine registry.");
})();
