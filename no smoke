
setInterval(function() {
    // We don't delete it; we redefine it so the game 
    // thinks it succeeded in making smoke, but nothing appears.
    elements.smoke = {
        color: "#00000000", // Transparent
        tool: false,        // Remove from menu
        hidden: true,       // Hide from lists
        state: "gas",
        onStep: function(pixel) {
            deletePixel(pixel.x, pixel.y); // Kill the pixel instantly
        },
        excludeRandom: true,
        noMix: true,
        movable: false
    };

    // Also, clear the 'fire' reaction specifically just in case
    if (elements.fire && elements.fire.reactions) {
        delete elements.fire.reactions.oxygen;
        delete elements.fire.reactions.air;
    }
}, 50);
